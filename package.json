{
  "name": "obsidian-csvzall",
  "version": "0.1.1",
  "description": "A fast CSV viewer, editor, and charting tool.",
  "main": "main.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincentlaucsb/obsidian-csvzall.git"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "npm run test:unit",
    "test:unit": "npm run build && node --test tests/*.test.mjs",
    "pretest:coverage": "node -e \"require('node:fs').mkdirSync('coverage', { recursive: true })\"",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-include=src/**/*.js --test-coverage-exclude=tests/**/*.mjs --test-reporter=spec --test-reporter=lcov --test-reporter-destination=stdout --test-reporter-destination=coverage/lcov.info tests/*.test.mjs"
  },
  "keywords": [
    "obsidian",
    "csv",
    "csvzall"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "esbuild": "0.25.5",
    "tslib": "2.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
